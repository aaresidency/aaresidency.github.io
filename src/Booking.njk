---
layout: base.njk
title: Book Your Stay | AA Residency Tirupati
description: Book your stay at AA Residency Tirupati. Choose from A/C Deluxe and Non-A/C Deluxe rooms. Enjoy free cancellation, family-friendly rooms, and the best rates near Tirupati Temple.
keywords: AA Residency Tirupati booking, Tirupati hotel booking, A/C Deluxe, Non-A/C Deluxe, family hotels Tirupati, free cancellation, best hotels near Tirupati temple
permalink: /Booking.html
bodyClass: page-booking
adsConversionLabel: Booking Page Visit
---

<div class="booking-container"
  {% if booking.apiUrl %}
  data-booking-api="{{ booking.apiUrl | escape }}"
  {% endif %}>
  <h1>Book Your Stay</h1>
  <form
    method="POST"
    id="bookingForm"
    autocomplete="off"
    data-track-form="booking_form_submit"
    {% if booking.apiUrl %}
    action="#"
    {% else %}
    action="https://api.web3forms.com/submit"
    {% endif %}
  >
    {% if not booking.apiUrl %}
    <input type="hidden" name="access_key" value="9f803485-d262-43e1-9d97-967612f625a8" />
    <input type="hidden" name="from_name" value="AA Residency Tirupati Website" />
    <input type="hidden" name="subject" id="bookingSubject" value="New Booking Enquiry - AA Residency Tirupati" />
    <input type="hidden" name="replyto" id="bookingReplyTo" value="" />
    <input type="hidden" name="booking_reference" id="bookingReference" value="" />
    <input type="hidden" name="booking_summary" id="bookingSummary" value="" />
    <input type="hidden" name="source_page" value="https://aaresidency.com/Booking.html" />
    <input type="hidden" name="redirect" value="https://aaresidency.com/Confirmation.html" />
    {% endif %}

    {% if booking.apiUrl %}
    <p class="booking-honeypot" aria-hidden="true">
      <label for="bookingWebsite">Company website</label>
      <input type="text" id="bookingWebsite" name="website" tabindex="-1" autocomplete="off" value="" />
    </p>
    {% endif %}

    <label for="guestName">Full Name</label>
    <input type="text" id="guestName" name="name" placeholder="Your full name" required />

    <label for="guestEmail">Email</label>
    <input type="email" id="guestEmail" name="email" placeholder="your@email.com" required />

    <label for="guestPhone">Phone</label>
    <input type="tel" id="guestPhone" name="phone" placeholder="Your phone number" pattern="[0-9]{10}" maxlength="10" inputmode="numeric" required />

    <label for="arrivalDate">Arrival Date</label>
    <input type="date" id="arrivalDate" name="arrival_date" required />

    <label for="departureDate">Departure Date</label>
    <input type="date" id="departureDate" name="departure_date" required />

    <label for="roomType">Room Type</label>
    <select id="roomType" name="room_type" required>
      <option value="">Select room type</option>
      <option value="A/C Deluxe">A/C Deluxe</option>
      <option value="Non-A/C Deluxe">Non-A/C Deluxe</option>
    </select>

    <div id="priceLabel" class="price-label"></div>

    <label for="adults">Number of Adults</label>
    <input type="number" id="adults" name="adults" min="1" max="10" value="1" required />

    <label for="children">Number of Children</label>
    <input type="number" id="children" name="children" min="0" max="10" value="0" required />

    <label for="notes">Notes or Requests (e.g., accessibility)</label>
    <textarea id="notes" name="notes" placeholder="Any special requests or accessibility needs?"></textarea>

    <button type="submit" data-track-action="booking_submit_click">Confirm Booking</button>
  </form>
  <p class="booking-note">
    {% if booking.apiUrl %}
    After you submit, we send a booking acknowledgement to your email and notify our team. Please check spam if you do not see it within a few minutes.
    {% else %}
    You will receive a booking acknowledgement by email after submission (if autoresponder is enabled in your form settings).
    {% endif %}
  </p>
</div>

<script>
  (function () {
    const form = document.getElementById("bookingForm");
    const container = document.querySelector(".booking-container");
    const bookingApiUrl = (container && container.dataset.bookingApi ? container.dataset.bookingApi : "").trim();

    function generateBookingReference() {
      const now = new Date();
      const y = now.getFullYear();
      const m = String(now.getMonth() + 1).padStart(2, "0");
      const d = String(now.getDate()).padStart(2, "0");
      const h = String(now.getHours()).padStart(2, "0");
      const min = String(now.getMinutes()).padStart(2, "0");
      const random = Math.floor(100 + Math.random() * 900);
      return "AAR-" + y + m + d + "-" + h + min + "-" + random;
    }

    function validateBookingFields() {
      const name = document.getElementById("guestName").value.trim();
      if (!name) {
        alert("Full Name is required.");
        document.getElementById("guestName").focus();
        return false;
      }
      const email = document.getElementById("guestEmail").value.trim();
      const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!email) {
        alert("Email is required.");
        document.getElementById("guestEmail").focus();
        return false;
      }
      if (!emailPattern.test(email)) {
        alert("Please enter a valid email address.");
        document.getElementById("guestEmail").focus();
        return false;
      }
      const phone = document.getElementById("guestPhone").value.trim();
      const phonePattern = /^[0-9]{10}$/;
      if (!phone) {
        alert("Phone number is required.");
        document.getElementById("guestPhone").focus();
        return false;
      }
      if (!phonePattern.test(phone)) {
        alert("Please enter a valid 10-digit phone number.");
        document.getElementById("guestPhone").focus();
        return false;
      }
      const arrival = document.getElementById("arrivalDate").value;
      if (!arrival) {
        alert("Arrival date is required.");
        document.getElementById("arrivalDate").focus();
        return false;
      }
      const departure = document.getElementById("departureDate").value;
      if (!departure) {
        alert("Departure date is required.");
        document.getElementById("departureDate").focus();
        return false;
      }
      return true;
    }

    function getApiErrorMessage(data) {
      if (!data) return "";
      if (typeof data.error === "string" && data.error.trim()) return data.error.trim();
      if (typeof data.message === "string" && data.message.trim()) return data.message.trim();

      const customerDetail = data.customer && data.customer.detail;
      const adminDetail = data.admin && data.admin.detail;
      const detail = customerDetail || adminDetail;
      if (typeof detail === "string" && detail.trim()) return detail.trim();
      if (detail && typeof detail === "object") {
        if (typeof detail.message === "string" && detail.message.trim()) return detail.message.trim();
        if (typeof detail.error === "string" && detail.error.trim()) return detail.error.trim();
      }
      return "";
    }

    const roomTypeEl = document.getElementById("roomType");
    const priceLabel = document.getElementById("priceLabel");
    roomTypeEl.addEventListener("change", function () {
      if (roomTypeEl.value === "A/C Deluxe") {
        priceLabel.textContent = "Price: ₹1700 (incl. all taxes)";
      } else if (roomTypeEl.value === "Non-A/C Deluxe") {
        priceLabel.textContent = "Price: ₹1200 (incl. all taxes)";
      } else {
        priceLabel.textContent = "";
      }
    });

    if (bookingApiUrl) {
      form.addEventListener("submit", function (e) {
        e.preventDefault();
        if (!validateBookingFields()) return;

        const roomTypeValue = document.getElementById("roomType").value;
        if (!roomTypeValue) {
          alert("Please select a room type.");
          document.getElementById("roomType").focus();
          return;
        }

        const adultsValue = document.getElementById("adults").value;
        const childrenValue = document.getElementById("children").value;
        const notesValue = document.getElementById("notes").value.trim();
        const honey = document.getElementById("bookingWebsite");
        const website = honey ? honey.value : "";

        const submitBtn = form.querySelector('button[type="submit"]');
        const prevText = submitBtn.textContent;
        submitBtn.disabled = true;
        submitBtn.textContent = "Sending…";

        fetch(bookingApiUrl, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            website: website,
            name: document.getElementById("guestName").value.trim(),
            email: document.getElementById("guestEmail").value.trim(),
            phone: document.getElementById("guestPhone").value.trim(),
            arrival_date: document.getElementById("arrivalDate").value,
            departure_date: document.getElementById("departureDate").value,
            room_type: roomTypeValue,
            adults: adultsValue,
            children: childrenValue,
            notes: notesValue,
          }),
        })
          .then(function (res) {
            return res
              .json()
              .catch(function () {
                return null;
              })
              .then(function (data) {
                return { res: res, data: data };
              });
          })
          .then(function (out) {
            if (!out.res.ok || !out.data || !out.data.ok) {
              const apiReason = getApiErrorMessage(out.data);
              const msg = apiReason
                ? "Booking request failed: " + apiReason
                : "We could not send your booking just now. Please call +91 99929 99961 or try again shortly.";
              alert(msg);
              return;
            }
            const ref = out.data.bookingRef || "";
            window.location.href = "/Confirmation.html?ref=" + encodeURIComponent(ref);
          })
          .catch(function () {
            alert("Network error. Please check your connection or call +91 99929 99961.");
          })
          .finally(function () {
            submitBtn.disabled = false;
            submitBtn.textContent = prevText;
          });
      });
    } else {
      form.addEventListener("submit", function (e) {
        if (!validateBookingFields()) {
          e.preventDefault();
          return;
        }
        const name = document.getElementById("guestName").value.trim();
        const email = document.getElementById("guestEmail").value.trim();
        const phone = document.getElementById("guestPhone").value.trim();
        const arrival = document.getElementById("arrivalDate").value;
        const departure = document.getElementById("departureDate").value;
        const roomTypeValue = document.getElementById("roomType").value;
        const adultsValue = document.getElementById("adults").value;
        const childrenValue = document.getElementById("children").value;
        const notesValue = document.getElementById("notes").value.trim() || "N/A";
        const bookingRef = generateBookingReference();

        document.getElementById("bookingReference").value = bookingRef;
        document.getElementById("bookingReplyTo").value = email;
        document.getElementById("bookingSubject").value = "New Booking Enquiry [" + bookingRef + "] - " + name;
        document.getElementById("bookingSummary").value =
          "Booking Ref: " +
          bookingRef +
          " | Guest: " +
          name +
          " | Phone: " +
          phone +
          " | Email: " +
          email +
          " | Arrival: " +
          arrival +
          " | Departure: " +
          departure +
          " | Room: " +
          roomTypeValue +
          " | Adults: " +
          adultsValue +
          " | Children: " +
          childrenValue +
          " | Notes: " +
          notesValue;
      });
    }
  })();
</script>
