<script>
  (function () {
    var block = document.getElementById("confirmationRefBlock");
    if (!block) return;
    var params = new URLSearchParams(window.location.search);
    var ref = params.get("ref");
    if (!ref || !/^[A-Za-z0-9\-]+$/.test(ref)) return;
    block.textContent = "Your booking reference: " + ref;
    block.hidden = false;
  })();
</script>
