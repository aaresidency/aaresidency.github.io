<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f172a" />
    {% if description %}
    <meta name="description" content="{{ description }}" />
    {% endif %}
    {% if keywords %}
    <meta name="keywords" content="{{ keywords }}" />
    {% endif %}
    <meta name="robots" content="{% if noindex %}noindex, follow{% else %}index, follow{% endif %}" />
    <meta name="author" content="AA Residency Tirupati" />
    <link rel="canonical" href="https://aaresidency.com{{ page.url }}" />
    {% if page.url == "/" %}
    {# LCP hint: first hero slide (WebP preferred by <picture>); matches images/home-slide-1.webp #}
    <link rel="preload" as="image" href="images/home-slide-1.webp" type="image/webp" />
    {% endif %}
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {# Non-blocking fonts — avoids render-blocking CSS from Google Fonts #}
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <meta property="og:type" content="website" />
    <meta property="og:title" content="{{ title }}" />
    {% if description %}
    <meta property="og:description" content="{{ description }}" />
    {% endif %}
    <meta property="og:url" content="https://aaresidency.com{{ page.url }}" />
    <meta property="og:site_name" content="AA Residency Tirupati" />
    <meta property="og:image" content="https://aaresidency.com{% if ogImage %}{{ ogImage }}{% else %}images/home-slide-1.jpg{% endif %}" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ title }}" />
    {% if description %}
    <meta name="twitter:description" content="{{ description }}" />
    {% endif %}
    <meta name="twitter:image" content="https://aaresidency.com{% if ogImage %}{{ ogImage }}{% else %}images/home-slide-1.jpg{% endif %}" />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Hotel",
        "name": "AA Residency Tirupati",
        "url": "https://aaresidency.com",
        "sameAs": ["https://maps.app.goo.gl/9AdeCWiaTHM4nEQW8"],
        "hasMap": "https://maps.app.goo.gl/9AdeCWiaTHM4nEQW8",
        "telephone": "+91-99929-99961",
        "email": "info@aaresidency.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "22-11-246/1, Gollavani Gunta, Renigunta Road",
          "addressLocality": "Tirupati",
          "addressRegion": "Andhra Pradesh",
          "postalCode": "517501",
          "addressCountry": "IN"
        },
        "amenityFeature": [
          { "@type": "LocationFeatureSpecification", "name": "Free Wi-Fi", "value": true },
          { "@type": "LocationFeatureSpecification", "name": "Family Rooms", "value": true },
          { "@type": "LocationFeatureSpecification", "name": "24/7 Front Desk", "value": true }
        ]
      }
    </script>
    {% if breadcrumb %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {% for item in breadcrumb %}
          {
            "@type": "ListItem",
            "position": {{ loop.index }},
            "name": {{ item.name | dump | safe }},
            "item": "https://aaresidency.com{{ item.url }}"
          }{% if not loop.last %},{% endif %}

          {% endfor %}
        ]
      }
    </script>
    {% endif %}
    <title>{{ title }}</title>
    <link rel="stylesheet" href="css/site.css" />
  </head>
  <body{% if bodyClass %} class="{{ bodyClass }}"{% endif %} data-hero-variant="{{ siteContext.heroVariant }}">
    <a class="skip-link" href="#main-content">Skip to main content</a>

    {# Hospitality-style utility strip: trust message + reachable contact shortcuts #}
    <div class="site-topbar" aria-label="Contact shortcuts and booking reassurance">
      <div class="site-topbar__inner">
        <p class="site-topbar__trust">
          <span class="site-topbar__trust-badge">Book direct</span>
          <span class="site-topbar__trust-dash" aria-hidden="true">•</span>
          <span>Renigunta Road, Tirupati · 24/7 reception</span>
        </p>
        <div class="site-topbar__actions">
          <a class="site-topbar__link site-topbar__link--email" href="mailto:info@aaresidency.com" data-track-action="topbar_email_click">
            <svg class="site-topbar__icon" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
              />
            </svg>
            <span class="site-topbar__link-text">info@aaresidency.com</span>
          </a>
          <a class="site-topbar__link site-topbar__link--phone" href="tel:+919992999961" data-track-action="topbar_phone_click">
            <svg class="site-topbar__icon" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.608-1.288.608-.705 0-1.258-.379-2.036-.764A18.934 18.934 0 016.72 15.53a18.651 18.651 0 01-3.441-3.441 18.934 18.934 0 01-1.676-5.395c0-.545.214-1.067.586-1.452l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
              />
            </svg>
            <span class="site-topbar__link-text">+91 99929 99961</span>
          </a>
          <a
            class="site-topbar__link site-topbar__link--whatsapp"
            href="https://wa.me/919992999961?text=Hello%20AA%20Residency%2C%20I%20would%20like%20help%20with%20a%20stay."
            target="_blank"
            rel="noopener noreferrer"
            data-track-action="topbar_whatsapp_click"
          >
            <svg class="site-topbar__icon site-topbar__icon--whatsapp" width="17" height="17" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
              />
            </svg>
            <span class="site-topbar__link-text">WhatsApp</span>
          </a>
        </div>
      </div>
    </div>

    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-brand" href="/" data-track-action="header_logo_click">
          <span class="site-brand__name">AA Residency</span>
          <span class="site-brand__line" aria-hidden="true"></span>
          <span class="site-brand__subtitle">Hotel in Tirupati</span>
        </a>

        <nav class="site-nav" aria-label="Primary">
          <a class="site-nav__link" href="about.html" {% if page.url == "/about.html" %}aria-current="page"{% endif %}>About</a>
          <a class="site-nav__link" href="ContactUs.html" {% if page.url == "/ContactUs.html" %}aria-current="page"{% endif %}>Contact</a>
          <a class="site-nav__link" href="guest-information.html" {% if page.url == "/guest-information.html" %}aria-current="page"{% endif %}>Guest info</a>
          <a class="site-nav__link" href="privacy-policy.html" {% if page.url == "/privacy-policy.html" %}aria-current="page"{% endif %}>Privacy</a>
          <a class="site-nav__book" href="Booking.html" {% if page.url == "/Booking.html" %}aria-current="page"{% endif %} data-track-action="header_book_now_click">
            Book now
          </a>
        </nav>
      </div>
    </header>

    <main id="main-content" tabindex="-1">
      {{ content | safe }}
    </main>

    {% if bodyClass != "page-confirmation" %}
    <div class="desktop-sticky-actions" aria-label="Desktop quick contact actions">
      <a
        href="tel:+919992999961"
        class="desktop-sticky-action desktop-sticky-action--call"
        aria-label="Call now"
        data-track-action="desktop_sticky_call_click"
      >
        Call
      </a>
      <a
        href="https://wa.me/919992999961?text=Hello%20AA%20Residency%2C%20I%20want%20to%20book%20a%20room."
        class="desktop-sticky-action desktop-sticky-action--whatsapp"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Chat on WhatsApp"
        data-track-action="desktop_sticky_whatsapp_click"
      >
        WhatsApp
      </a>
      <a
        href="Booking.html"
        class="desktop-sticky-action desktop-sticky-action--book"
        aria-label="Book your stay now"
        data-track-action="desktop_sticky_book_click"
      >
        Book
      </a>
    </div>
    <div class="mobile-sticky-actions" aria-label="Quick contact actions">
      <a
        href="tel:+919992999961"
        class="mobile-sticky-action mobile-sticky-action--call"
        aria-label="Call now"
        data-track-action="sticky_call_click"
      >
        Call
      </a>
      <a
        href="https://wa.me/919992999961?text=Hello%20AA%20Residency%2C%20I%20want%20to%20book%20a%20room."
        class="mobile-sticky-action mobile-sticky-action--whatsapp"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Chat on WhatsApp"
        data-track-action="sticky_whatsapp_click"
      >
        WhatsApp
      </a>
      <a
        href="Booking.html"
        class="mobile-sticky-action mobile-sticky-action--book"
        aria-label="Book your stay now"
        data-track-action="sticky_book_click"
      >
        Book Now
      </a>
    </div>
    {% endif %}

    <footer class="site-footer">
      <div class="footer-left">
        <div>AA Residency Tirupati</div>
        <p class="footer-rates-note">
          Indicative rates on our booking page reviewed <time datetime="{{ siteContext.ratesEffectiveISO }}">{{ siteContext.ratesEffectiveLabel }}</time>.
        </p>
      </div>
      <div class="footer-right">
        <div>
          <h4>Popular Pages</h4>
          <p>
            <a href="hotels-in-tirupati.html">Hotels in Tirupati</a><br />
            <a href="rooms-in-tirupati.html">Rooms in Tirupati</a><br />
            <a href="hotels-near-tirupati-temple.html">Hotels Near Tirupati Temple</a>
          </p>
        </div>
        <div>
          <h4>Location</h4>
          <address>
            <a
              href="https://maps.app.goo.gl/9AdeCWiaTHM4nEQW8"
              target="_blank"
              rel="noopener noreferrer"
              class="footer-location-link"
              aria-label="Open AA Residency Tirupati in Google Maps"
            >
              22-11-246/1, Gollavani Gunta<br />
              Renigunta Road, Tirupati 517501
            </a>
          </address>
        </div>
        <div>
          <h4>Contact</h4>
          <p>
            Phone: <a href="tel:+919992999961">+91 99929 99961</a><br />
            Email: <a href="mailto:info@aaresidency.com">info@aaresidency.com</a>
          </p>
        </div>
        <div>
          <h4>Guest care &amp; legal</h4>
          <p>
            <a href="guest-information.html">Booking &amp; stay information</a><br />
            <a href="privacy-policy.html">Privacy policy</a>
          </p>
        </div>
      </div>
    </footer>
    {# Google tag at end of body so first paint is not blocked #}
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-17283929589"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'AW-17283929589');
      {% if siteContext.gaMeasurementId %}
      gtag('config', '{{ siteContext.gaMeasurementId }}');
      {% endif %}
      {% if adsConversionLabel %}
      gtag('event', 'conversion', {
        send_to: 'AW-17283929589/{{ adsConversionLabel }}',
      });
      {% endif %}
      {% if siteContext.gaMeasurementId and bodyClass == "page-home" %}
      gtag('event', 'experiment_exposure', {
        experiment_id: 'home_hero',
        variant_id: '{{ siteContext.heroVariant }}',
        page_location: window.location.href,
        page_path: window.location.pathname,
      });
      {% endif %}
    </script>
    <script>
      (function () {
        const trackedActions = document.querySelectorAll("[data-track-action]");
        if (!trackedActions.length) return;

        const heroVariant = document.body.getAttribute("data-hero-variant") || "a";

        trackedActions.forEach(function (element) {
          element.addEventListener("click", function () {
            const actionName = element.getAttribute("data-track-action");
            if (!actionName || typeof window.gtag !== "function") return;

            window.gtag("event", actionName, {
              event_category: "engagement",
              event_label: window.location.pathname,
              hero_variant: heroVariant,
              transport_type: "beacon",
            });
          });
        });

        const trackedForms = document.querySelectorAll("form[data-track-form]");
        trackedForms.forEach(function (form) {
          form.addEventListener("submit", function () {
            const formActionName = form.getAttribute("data-track-form");
            if (!formActionName || typeof window.gtag !== "function") return;

            window.gtag("event", formActionName, {
              event_category: "lead",
              event_label: window.location.pathname,
              hero_variant: heroVariant,
              transport_type: "beacon",
            });
            window.gtag("event", "generate_lead", {
              form_name: formActionName,
              page_location: window.location.href,
              page_path: window.location.pathname,
              hero_variant: heroVariant,
              transport_type: "beacon",
            });
          });
        });
      })();
    </script>
  </body>
</html>
