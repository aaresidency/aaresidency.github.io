<script>
  (function () {
    const slider = document.getElementById("heroSlider");
    if (!slider) return;
    const slides = slider.querySelectorAll(".home-hero__slide");
    const prevBtn = document.querySelector(".slider-nav--prev");
    const nextBtn = document.querySelector(".slider-nav--next");
    const dotsWrap = document.getElementById("sliderDots");
    let currentIndex = 0;
    let timer = null;
    let touchStartX = 0;
    let touchEndX = 0;

    slides.forEach(function (_, index) {
      const dot = document.createElement("button");
      dot.type = "button";
      dot.className = "slider-dot" + (index === 0 ? " is-active" : "");
      dot.setAttribute("aria-label", "View image " + (index + 1));
      dot.addEventListener("click", function () {
        showSlide(index, "dot");
        resetAuto();
      });
      dotsWrap.appendChild(dot);
    });

    const dots = dotsWrap.querySelectorAll(".slider-dot");

    function showSlide(index, interactionSource) {
      slides[currentIndex].classList.remove("is-active");
      dots[currentIndex].classList.remove("is-active");
      currentIndex = (index + slides.length) % slides.length;
      slides[currentIndex].classList.add("is-active");
      dots[currentIndex].classList.add("is-active");
      if (interactionSource && typeof window.gtag === "function") {
        window.gtag("event", "hero_slide_engagement", {
          slide_index: currentIndex,
          hero_interaction: interactionSource,
          hero_variant: document.body.getAttribute("data-hero-variant") || "a",
          page_path: window.location.pathname,
          transport_type: "beacon",
        });
      }
    }

    function startAuto() {
      timer = setInterval(function () {
        showSlide(currentIndex + 1);
      }, 4500);
    }

    function resetAuto() {
      clearInterval(timer);
      startAuto();
    }

    prevBtn.addEventListener("click", function () {
      showSlide(currentIndex - 1, "prev");
      resetAuto();
    });

    nextBtn.addEventListener("click", function () {
      showSlide(currentIndex + 1, "next");
      resetAuto();
    });

    document.addEventListener("keydown", function (event) {
      const activeTag = document.activeElement ? document.activeElement.tagName : "";
      if (activeTag === "INPUT" || activeTag === "TEXTAREA" || activeTag === "SELECT") {
        return;
      }
      if (event.key === "ArrowLeft") {
        showSlide(currentIndex - 1, "keyboard");
        resetAuto();
      } else if (event.key === "ArrowRight") {
        showSlide(currentIndex + 1, "keyboard");
        resetAuto();
      }
    });

    slider.addEventListener("touchstart", function (event) {
      touchStartX = event.changedTouches[0].screenX;
    });

    slider.addEventListener("touchend", function (event) {
      touchEndX = event.changedTouches[0].screenX;
      const delta = touchEndX - touchStartX;
      if (Math.abs(delta) < 40) return;
      if (delta > 0) {
        showSlide(currentIndex - 1, "swipe");
      } else {
        showSlide(currentIndex + 1, "swipe");
      }
      resetAuto();
    });

    startAuto();
  })();
</script>
